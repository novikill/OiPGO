<Window x:Class="lab5.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Битва героев" Height="758.14" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e">

    <Window.Resources>
        <!-- Стиль для кнопок -->
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#0f3460"/>
            <Setter Property="Foreground" Value="#e94560"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#e94560"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e94560"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#2d2d3a"/>
                    <Setter Property="BorderBrush" Value="#555555"/>
                    <Setter Property="Foreground" Value="#888888"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для текстовых блоков -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#eeeeee"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- Стиль для текстовых полей -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="Foreground" Value="#eeeeee"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderBrush" Value="#e94560"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Стиль для ListBox -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="Foreground" Value="#eeeeee"/>
            <Setter Property="BorderBrush" Value="#e94560"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Стиль для карточек -->
        <Style x:Key="InfoCard" TargetType="Border">
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="BorderBrush" Value="#e94560"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid" Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Верхний баннер -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" 
                Background="#0f3460" 
                Padding="8" 
                CornerRadius="8" 
                Margin="0,0,0,5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="⚔️" FontSize="20" Margin="0,0,8,0"/>
                <TextBlock Text="BATTLE ARENA" FontSize="20" FontWeight="Bold" 
                           Foreground="#e94560" FontFamily="Consolas"/>
                <TextBlock Text="⚔️" FontSize="20" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Левая панель - Профиль героя -->
        <ScrollViewer Grid.Row="1" Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,5,0">
            <Border Background="#0f3460" CornerRadius="10" Padding="10">
                <StackPanel>
                    <!-- Аватар героя -->
                    <Border Background="#16213e" CornerRadius="25" Height="70" Width="70" 
                            HorizontalAlignment="Center" Margin="0,0,0,12"
                            BorderBrush="#e94560" BorderThickness="2">
                        <TextBlock Text="👤" FontSize="35" HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="🚀 СТАТИСТИКА" FontSize="14" FontWeight="Bold" 
                               HorizontalAlignment="Center" Margin="0,0,0,10" 
                               Foreground="#e94560"/>

                    <Border Style="{StaticResource InfoCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🏆 РАНГ" FontWeight="Bold" Margin="0,0,12,0"/>
                            <TextBlock x:Name="LvlText" Grid.Column="1" Text="1" FontSize="18" 
                                       FontWeight="Bold" Foreground="#feca57" TextAlignment="Right"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource InfoCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="💰 МОНЕТЫ" FontWeight="Bold" Margin="0,0,12,0"/>
                            <TextBlock x:Name="GoldText" Grid.Column="1" Text="0" FontSize="18" 
                                       FontWeight="Bold" Foreground="#feca57" TextAlignment="Right"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource InfoCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="⚡ СИЛА" FontWeight="Bold" Margin="0,0,12,0"/>
                            <TextBlock x:Name="DamageText" Grid.Column="1" Text="10" FontSize="18" 
                                       FontWeight="Bold" Foreground="#ff6b6b" TextAlignment="Right"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource InfoCard}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔧 АПГРЕЙД" FontWeight="Bold" Margin="0,0,12,0"/>
                            <TextBlock x:Name="UpgradeCostText" Grid.Column="1" Text="100" FontSize="14" 
                                       FontWeight="Bold" Foreground="#feca57" TextAlignment="Right"/>
                        </Grid>
                    </Border>

                    <Button x:Name="UpgradeButton" Content="🔨 ПРОКАЧАТЬ СИЛУ" 
                            Click="UpgradeButton_Click" Margin="0,8,0,5" Height="38"/>

                    <!-- Секция перезарядки -->
                    <Border Style="{StaticResource InfoCard}">
                        <StackPanel>
                            <TextBlock Text="⏱️ ЗАДЕРЖКА АТАКИ" FontWeight="Bold" 
                                       HorizontalAlignment="Center" Foreground="#e94560" FontSize="12"/>
                            <TextBlock x:Name="CooldownText" Text="Готов!" FontSize="11" 
                                       Foreground="#feca57" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            <Separator Margin="0,6" Background="#e94560"/>
                            <TextBlock Text="💰 ЦЕНА" FontSize="10" 
                                       HorizontalAlignment="Center" Foreground="#aaaaaa"/>
                            <TextBlock x:Name="UpgradeCooldownCostText" Text="100" FontSize="14" 
                                       FontWeight="Bold" Foreground="#feca57" HorizontalAlignment="Center"/>
                            <Button x:Name="UpgradeCooldownButton" Content="⚡ УЛУЧШИТЬ" 
                                    Click="UpgradeCooldownButton_Click" Margin="0,6,0,0" Height="30"/>
                        </StackPanel>
                    </Border>

                    <!-- Бонусы и ослабления -->
                    <TextBlock x:Name="DamageBoostText" Text="" FontSize="10" 
                               Foreground="#ff6b6b" HorizontalAlignment="Center" 
                               TextWrapping="Wrap" Margin="0,5"/>
                    <TextBlock x:Name="WeakenText" Text="" FontSize="10" 
                               Foreground="#feca57" HorizontalAlignment="Center" 
                               TextWrapping="Wrap" Margin="0,3"/>

                    <!-- Кнопки управления -->
                    <Button x:Name="LoadEnemiesButton" Content="📂 ЗАГРУЗИТЬ ВРАГОВ" 
                            Click="LoadEnemiesButton_Click" Margin="0,8,0,3" Height="35"/>

                    <Button x:Name="SaveGameButton" Content="💾 СОХРАНИТЬ" 
                            Click="SaveGameButton_Click" Margin="0,3,0,3" Height="32"/>

                    <Button x:Name="LoadGameButton" Content="📁 ЗАГРУЗИТЬ" 
                            Click="LoadGameButton_Click" Margin="0,3,0,5" Height="32"/>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Правая панель - Арена битвы и лог событий -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="5,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <!-- Верхняя часть - информация о противнике -->
            <Border Grid.Row="0" Background="#0f3460" CornerRadius="10" Padding="10">
                <StackPanel>
                    <TextBlock Text="👾 АРЕНА" FontSize="14" FontWeight="Bold" 
                               HorizontalAlignment="Center" Margin="0,0,0,10" 
                               Foreground="#e94560"/>

                    <!-- Карточка врага -->
                    <Border Background="#16213e" CornerRadius="14" Padding="15" 
                            HorizontalAlignment="Center" Width="260" Height="280"
                            BorderBrush="#e94560" BorderThickness="1">
                        <StackPanel>
                            <Image x:Name="EnemyImage" Width="100" Height="100" 
                                   HorizontalAlignment="Center" Margin="0,8"/>
                            <TextBlock x:Name="EnemyNameText" Text="❓ НЕТ ВРАГА" 
                                       FontSize="15" FontWeight="Bold" 
                                       HorizontalAlignment="Center" Margin="0,8"
                                       Foreground="#e94560"/>
                            <TextBlock x:Name="EnemyTypeText" Text="" FontSize="10" 
                                       Foreground="#feca57" HorizontalAlignment="Center" 
                                       Margin="0,3"/>

                            <Separator Margin="0,8" Background="#e94560"/>

                            <TextBlock Text="❤️ ЗДОРОВЬЕ" FontSize="11" 
                                       HorizontalAlignment="Center" Margin="0,8,0,0"
                                       Foreground="#aaaaaa"/>
                            <TextBlock x:Name="EnemyHealthText" Text="0" FontSize="20" 
                                       FontWeight="Bold" Foreground="#ff6b6b" 
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="💎 НАГРАДА" FontSize="11" 
                                       HorizontalAlignment="Center" Margin="0,8,0,0"
                                       Foreground="#aaaaaa"/>
                            <TextBlock x:Name="EnemyRewardText" Text="0" FontSize="14" 
                                       Foreground="#feca57" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Button x:Name="AttackButton" Content="💥 НАПАДЕНИЕ 💥" 
                            Click="AttackButton_Click" Margin="0,20" 
                            Background="#e94560" Foreground="White"
                            FontSize="16" Height="48" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- Нижняя часть - лог событий -->
            <Border Grid.Row="1" Background="#0f3460" CornerRadius="10" Padding="10" Margin="0,5,0,0">
                <StackPanel>
                    <TextBlock Text="📋 ЛОГ СОБЫТИЙ" FontSize="12" FontWeight="Bold" 
                               HorizontalAlignment="Center" Margin="0,0,0,5" Foreground="#e94560"/>
                    <ListBox x:Name="EventLogListBox" Background="#16213e" 
                             Foreground="#eeeeee" FontSize="10" 
                             Height="140" BorderThickness="0" BorderBrush="#e94560">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="2"/>
                                <Setter Property="Padding" Value="3"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Нижняя панель - Статистика -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" 
                Background="#0f3460" 
                Padding="8" 
                CornerRadius="8" 
                Margin="0,5,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="EnemiesDefeatedText" Text="🏆 ПОБЕД: 0" 
                           FontSize="11" Margin="15,0" Foreground="#feca57"/>
                <TextBlock x:Name="TotalDamageText" Text="💥 УРОН: 0" 
                           FontSize="11" Margin="15,0" Foreground="#ff6b6b"/>
                <TextBlock x:Name="HighestDamageText" Text="⭐ РЕКОРД: 0" 
                           FontSize="11" Margin="15,0" Foreground="#00d2d3"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>