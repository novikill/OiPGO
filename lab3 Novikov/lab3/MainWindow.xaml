<Window x:Class="Lab2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Битва героев" Height="928" Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e">

    <Window.Resources>
        <!-- Стиль для кнопок -->
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Background" Value="#0f3460"/>
            <Setter Property="Foreground" Value="#e94560"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#e94560"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e94560"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#2d2d3a"/>
                    <Setter Property="BorderBrush" Value="#555555"/>
                    <Setter Property="Foreground" Value="#888888"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для текстовых блоков -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#eeeeee"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- Стиль для текстовых полей -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="Foreground" Value="#eeeeee"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="BorderBrush" Value="#e94560"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Стиль для карточек информации -->
        <Style x:Key="InfoCard" TargetType="Border">
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,8"/>
            <Setter Property="BorderBrush" Value="#e94560"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.3*"/>
            <ColumnDefinition Width="1.7*"/>
        </Grid.ColumnDefinitions>

        <!-- Верхний баннер -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" 
                Background="#0f3460" 
                Padding="12" 
                CornerRadius="8"
                Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="⚔️" FontSize="24" Margin="0,0,10,0"/>
                <TextBlock Text="BATTLE ARENA" FontSize="24" FontWeight="Bold" 
                           Foreground="#e94560" FontFamily="Consolas"/>
                <TextBlock Text="⚔️" FontSize="24" Margin="10,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Левая панель - Профиль героя -->
        <Border Grid.Row="1" Grid.Column="0" 
                Background="#0f3460" 
                Margin="0,0,8,0" 
                CornerRadius="12" 
                Padding="14">
            <StackPanel>
                <!-- Аватар героя -->
                <Border Background="#16213e" CornerRadius="30" Height="80" Width="80" 
                        HorizontalAlignment="Center" Margin="0,0,0,15"
                        BorderBrush="#e94560" BorderThickness="2">
                    <TextBlock Text="👤" FontSize="40" HorizontalAlignment="Center" 
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="🚀 СТАТИСТИКА" FontSize="16" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,12" 
                           Foreground="#e94560"/>

                <!-- Показатели -->
                <Border Style="{StaticResource InfoCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🏆 РАНГ" FontWeight="Bold" Margin="0,0,15,0"/>
                        <TextBlock x:Name="LvlText" Grid.Column="1" Text="1" FontSize="20" 
                                   FontWeight="Bold" Foreground="#feca57" TextAlignment="Right"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource InfoCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="💰 МОНЕТЫ" FontWeight="Bold" Margin="0,0,15,0"/>
                        <TextBlock x:Name="GoldText" Grid.Column="1" Text="0" FontSize="20" 
                                   FontWeight="Bold" Foreground="#feca57" TextAlignment="Right"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource InfoCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="⚡ СИЛА" FontWeight="Bold" Margin="0,0,15,0"/>
                        <TextBlock x:Name="DamageText" Grid.Column="1" Text="10" FontSize="20" 
                                   FontWeight="Bold" Foreground="#ff6b6b" TextAlignment="Right"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource InfoCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🔧 АПГРЕЙД" FontWeight="Bold" Margin="0,0,15,0"/>
                        <TextBlock x:Name="UpgradeCostText" Grid.Column="1" Text="100" FontSize="16" 
                                   FontWeight="Bold" Foreground="#feca57" TextAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- Секция перезарядки -->
                <Border Style="{StaticResource InfoCard}">
                    <StackPanel>
                        <TextBlock Text="⏱️ ЗАДЕРЖКА" FontWeight="Bold" 
                                   HorizontalAlignment="Center" Foreground="#e94560"/>
                        <TextBlock x:Name="CooldownText" Text="Готов!" FontSize="13" 
                                   Foreground="#feca57" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        <Separator Margin="0,8" Background="#e94560"/>
                        <TextBlock Text="💰 ЦЕНА УЛУЧШЕНИЯ" FontSize="11" 
                                   HorizontalAlignment="Center" Foreground="#aaaaaa"/>
                        <TextBlock x:Name="UpgradeCooldownCostText" Text="100" FontSize="16" 
                                   FontWeight="Bold" Foreground="#feca57" HorizontalAlignment="Center"/>
                        <Button x:Name="UpgradeCooldownButton" Content="⚡ УЛУЧШИТЬ" 
                                Click="UpgradeCooldownButton_Click" Margin="0,8,0,0" Height="32"/>
                    </StackPanel>
                </Border>

                <!-- Бонусы -->
                <TextBlock x:Name="DamageBoostText" Text="" FontSize="11" 
                           Foreground="#ff6b6b" HorizontalAlignment="Center" 
                           TextWrapping="Wrap" Margin="0,8"/>

                <Button x:Name="UpgradeButton" Content="🔨 ПРОКАЧАТЬ СИЛУ" 
                        Click="UpgradeButton_Click" Margin="0,10,0,8" Height="42"/>

                <Button x:Name="LoadEnemiesButton" Content="📂 ЗАГРУЗИТЬ ВРАГОВ" 
                        Click="LoadEnemiesButton_Click" Margin="0,8,0,0" Height="40"/>
            </StackPanel>
        </Border>

        <!-- Правая панель - Арена битвы -->
        <Border Grid.Row="1" Grid.Column="1" 
                Background="#0f3460" 
                Margin="8,0,0,0" 
                CornerRadius="12" 
                Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Панель противника -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="👾 АРЕНА" FontSize="16" FontWeight="Bold" 
                               HorizontalAlignment="Center" Margin="0,0,0,12" 
                               Foreground="#e94560"/>

                    <!-- Карточка врага -->
                    <Border Background="#16213e" CornerRadius="16" Padding="15" 
                            HorizontalAlignment="Center" Width="280" Height="310"
                            BorderBrush="#e94560" BorderThickness="1">
                        <StackPanel>
                            <Image x:Name="EnemyImage" Width="120" Height="120" 
                                   HorizontalAlignment="Center" Margin="0,10"/>
                            <TextBlock x:Name="EnemyNameText" Text="❓ НЕТ ВРАГА" 
                                       FontSize="17" FontWeight="Bold" 
                                       HorizontalAlignment="Center" Margin="0,12"
                                       Foreground="#e94560"/>

                            <Separator Margin="0,5" Background="#e94560" Height="1"/>

                            <TextBlock Text="❤️ ЗДОРОВЬЕ" FontSize="12" 
                                       HorizontalAlignment="Center" Margin="0,10,0,0"
                                       Foreground="#aaaaaa"/>
                            <TextBlock x:Name="EnemyHealthText" Text="0" FontSize="24" 
                                       FontWeight="Bold" Foreground="#ff6b6b" 
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="💎 НАГРАДА" FontSize="12" 
                                       HorizontalAlignment="Center" Margin="0,8,0,0"
                                       Foreground="#aaaaaa"/>
                            <TextBlock x:Name="EnemyRewardText" Text="0" FontSize="18" 
                                       Foreground="#feca57" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Кнопка атаки -->
                    <Button x:Name="AttackButton" Content="💥 НАПАДЕНИЕ 💥" 
                            Click="AttackButton_Click" Margin="0,22,0,0" 
                            Background="#e94560" Foreground="White"
                            FontSize="20" Height="55" FontWeight="Bold"/>
                </StackPanel>

                <!-- Область для бонусов -->
                <Canvas x:Name="SphereCanvas" Grid.Column="1" 
                        Width="250" Height="500" Margin="15,0,0,0"
                        Background="Transparent"
                        IsHitTestVisible="True"/>
            </Grid>
        </Border>

        <!-- Нижняя панель - Статистика -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" 
                Background="#0f3460" 
                Padding="10" 
                CornerRadius="8"
                Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="EnemiesDefeatedText" Text="🏆 ПОБЕД: 0" 
                           FontSize="13" Margin="20,0" Foreground="#feca57"/>
                <TextBlock x:Name="TotalDamageText" Text="💥 УРОН: 0" 
                           FontSize="13" Margin="20,0" Foreground="#ff6b6b"/>
                <TextBlock x:Name="HighestDamageText" Text="⭐ РЕКОРД: 0" 
                           FontSize="13" Margin="20,0" Foreground="#00d2d3"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>