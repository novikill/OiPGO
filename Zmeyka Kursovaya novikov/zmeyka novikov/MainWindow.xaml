<Window x:Class="SnakeGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Змейка" Height="650" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e"
        ResizeMode="CanResize"
        MinHeight="550" MinWidth="750">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="#0f3460"/>
            <Setter Property="Foreground" Value="#e94560"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#e94560"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#e94560"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#eeeeee"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#eeeeee"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#16213e"/>
            <Setter Property="Foreground" Value="#eeeeee"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderBrush" Value="#e94560"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#0f3460" Padding="8" CornerRadius="8" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="🐍" FontSize="24" Margin="0,0,10,0"/>
                <TextBlock Text="SNAKE GAME" FontSize="24" FontWeight="Bold" Foreground="#e94560" FontFamily="Consolas"/>
                <TextBlock Text="🐍" FontSize="24" Margin="10,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Игровое поле - уменьшенный размер -->
        <Border Grid.Row="1" Grid.Column="0" Background="#16213e" BorderBrush="#e94560" BorderThickness="2" CornerRadius="10" Margin="0,0,10,0"
                HorizontalAlignment="Center" VerticalAlignment="Top" Width="450" Height="450">
            <Canvas x:Name="GameCanvas" Background="#0f3460" ClipToBounds="True" Margin="1,1,1,1"/>
        </Border>

        <!-- Правая панель управления -->
        <Border Grid.Row="1" Grid.Column="1" Background="#0f3460" BorderBrush="#e94560" BorderThickness="2" CornerRadius="10" Padding="10">
            <StackPanel>
                <TextBlock Text="📊 ИНФОРМАЦИЯ" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15" Foreground="#e94560"/>

                <Border Background="#16213e" CornerRadius="8" Padding="10" Margin="0,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🐍 Счет:" FontWeight="Bold" Margin="0,0,15,0"/>
                        <TextBlock x:Name="ScoreText" Grid.Column="1" Text="0" FontSize="18" FontWeight="Bold" Foreground="#feca57" TextAlignment="Right"/>
                    </Grid>
                </Border>

                <Border Background="#16213e" CornerRadius="8" Padding="10" Margin="0,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🏆 Рекорд:" FontWeight="Bold" Margin="0,0,15,0"/>
                        <TextBlock x:Name="HighScoreText" Grid.Column="1" Text="0" FontSize="18" FontWeight="Bold" Foreground="#e94560" TextAlignment="Right"/>
                    </Grid>
                </Border>

                <Border Background="#16213e" CornerRadius="8" Padding="10" Margin="0,5" Height="45">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="⚡ Скорость:" FontWeight="Bold" Margin="0,0,15,0"/>
                        <TextBlock x:Name="SpeedText" Grid.Column="1" Text="5" FontSize="18" FontWeight="Bold" Foreground="#ff6b6b" TextAlignment="Right"/>
                    </Grid>
                </Border>

                <Separator Margin="0,15" Background="#e94560"/>

                <TextBlock Text="🎮 НАСТРОЙКИ" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5" Foreground="#e94560"/>

                <CheckBox x:Name="HardModeCheckBox" Content="Усложненный режим (препятствия)" Margin="0,5" Foreground="#eeeeee"/>

                <Border Background="#16213e" CornerRadius="8" Padding="10" Margin="0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="📐 Размер поля:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ComboBox x:Name="GridSizeComboBox" Width="100" HorizontalAlignment="Right">
                            <ComboBoxItem Content="15x15" Tag="15"/>
                            <ComboBoxItem Content="20x20" Tag="20" IsSelected="True"/>
                            <ComboBoxItem Content="25x25" Tag="25"/>
                            <ComboBoxItem Content="30x30" Tag="30"/>
                        </ComboBox>
                    </Grid>
                </Border>

                <Button x:Name="StartButton" Content="▶ СТАРТ" Click="StartButton_Click" Margin="0,10" Height="40"/>
                <Button x:Name="ResetButton" Content="🔄 СБРОС" Click="ResetButton_Click" Height="40"/>
                <Button x:Name="PauseButton" Content="⏸ ПАУЗА" Click="PauseButton_Click" Margin="0,5" Height="40" IsEnabled="False"/>

                <Separator Margin="0,15" Background="#e94560"/>

                <TextBlock Text="🎯 УПРАВЛЕНИЕ" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5" Foreground="#aaaaaa"/>
                <TextBlock Text="⬆️ ⬇️ ⬅️ ➡️ - Стрелки" FontSize="11" HorizontalAlignment="Center" Foreground="#aaaaaa"/>
                <TextBlock Text="Пробел - Пауза" FontSize="11" HorizontalAlignment="Center" Foreground="#aaaaaa"/>
                <TextBlock Text="R - Сброс" FontSize="11" HorizontalAlignment="Center" Foreground="#aaaaaa"/>
            </StackPanel>
        </Border>

        <!-- Статусная строка -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#0f3460" CornerRadius="8" Padding="8" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="GameStatusText" Text="Готов к игре! Нажмите СТАРТ! Управление на стрелки!!" FontSize="12" Foreground="#feca57"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>